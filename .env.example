# ═══════════════════════════════════════════════════════════════
# YourRAG Gateway — Unified Configuration
# Merges: P1 (demo) + P2 (production) + P3 (private deployment)
# ═══════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────
YOURRAG_APP_HOST=0.0.0.0
YOURRAG_APP_PORT=9382
YOURRAG_LOG_LEVEL=INFO
YOURRAG_LOG_JSON=true
YOURRAG_CORS_ORIGINS=["*"]

# ── LLM Provider ─────────────────────────────────────────────
# Options: ollama | openai | litellm
YOURRAG_LLM_PROVIDER=litellm

# Ollama (P1 — local-first)
YOURRAG_OLLAMA_BASE_URL=http://localhost:11434
YOURRAG_OLLAMA_MODEL=qwen2.5:7b

# OpenAI (P2 — cloud)
YOURRAG_OPENAI_API_KEY=
YOURRAG_OPENAI_MODEL=gpt-4.1

# Embedding
YOURRAG_EMBEDDING_MODEL=text-embedding-3-large
YOURRAG_EMBEDDING_DIMENSION=1024

# ── Vector Store ──────────────────────────────────────────────
# Options: chroma | sqlite | pinecone | elasticsearch | infinity | oceanbase | opensearch
YOURRAG_VECTOR_STORE_BACKEND=elasticsearch
YOURRAG_CHROMA_DIR=./data/chroma
YOURRAG_CHROMA_COLLECTION=yourrag_docs
YOURRAG_PINECONE_API_KEY=
YOURRAG_PINECONE_INDEX_NAME=yourrag
YOURRAG_RETRIEVAL_TOP_K=4

# ── RAG Pipeline ──────────────────────────────────────────────
YOURRAG_CHUNK_SIZE=700
YOURRAG_CHUNK_OVERLAP=80

# ── Agent Mode ────────────────────────────────────────────────
# Options: react | canvas
YOURRAG_AGENT_MODE=canvas
YOURRAG_MAX_AGENT_STEPS=5

# ── P1: Tool Executor (Circuit Breaker) ───────────────────────
YOURRAG_TOOL_TIMEOUT_SECONDS=8
YOURRAG_TOOL_RETRY_ATTEMPTS=2
YOURRAG_TOOL_RETRY_BACKOFF_SECONDS=0.4
YOURRAG_TOOL_CIRCUIT_BREAKER_THRESHOLD=3
YOURRAG_TOOL_CIRCUIT_BREAKER_COOLDOWN_SECONDS=30

# ── P1: SSE Streaming ────────────────────────────────────────
YOURRAG_SSE_CHUNK_SIZE=14

# ── P1: Session Memory (JSON fallback) ───────────────────────
YOURRAG_MEMORY_PATH=./data/session_memory.json

# ── P2: Ingestion Queue ──────────────────────────────────────
YOURRAG_INGESTION_QUEUE_BACKEND=sqlite
YOURRAG_INGESTION_MAX_RETRIES=3
YOURRAG_INGESTION_WORKER_POLL_SECONDS=1.0
YOURRAG_INGESTION_EMBEDDED_WORKER_ENABLED=true

# ── P2: JWT + RBAC Auth ──────────────────────────────────────
YOURRAG_SECURITY_ENABLED=true
YOURRAG_JWT_SECRET=change-me-in-production
YOURRAG_JWT_ISSUER=yourrag
YOURRAG_JWT_ACCESS_TOKEN_EXP_MINUTES=60
YOURRAG_BOOTSTRAP_ADMIN_USERNAME=admin
YOURRAG_BOOTSTRAP_ADMIN_PASSWORD=admin123

# ── P2: Rate Limiting ────────────────────────────────────────
YOURRAG_RATE_LIMIT_PER_MINUTE=120

# ── P2: Tavily Search ────────────────────────────────────────
YOURRAG_TAVILY_API_KEY=  # gitleaks:ignore
YOURRAG_TAVILY_MAX_RESULTS=3

# ── Redis ─────────────────────────────────────────────────────
YOURRAG_REDIS_URL=

# ── P2: Observability ────────────────────────────────────────
YOURRAG_PROMETHEUS_ENABLED=true
YOURRAG_OPEN_TELEMETRY_ENABLED=false
YOURRAG_OTEL_EXPORTER_OTLP_ENDPOINT=
YOURRAG_OTEL_SERVICE_NAME=yourrag

# ── P2: Mock/Live Toggle ─────────────────────────────────────
YOURRAG_USE_MOCK_SERVICES=false

# ── P3: Database ──────────────────────────────────────────────
YOURRAG_DATABASE_PATH=data/yourrag.db

# ── P3: Encryption at Rest ───────────────────────────────────
YOURRAG_CRYPTO_ENABLED=false
YOURRAG_CRYPTO_SECRET_KEY=

# ── P3 Engine Configuration ──────────────────────────────────
# These are read by P3's existing common/settings.py
# (See conf/service_conf.yaml for full P3 config)
RAGFLOW_VERSION=1.0.0
DOC_ENGINE=elasticsearch
