# Lightweight local profile for quick validation
# Copy to docker/.env.local.lite and use with:
# docker compose --env-file .env.local.lite -f docker-compose.yml up -d

DOC_ENGINE=infinity
DEVICE=cpu
COMPOSE_PROFILES=${DOC_ENGINE},${DEVICE}
COMPOSE_PROJECT_NAME=yourrag-lite

SVR_WEB_HTTP_PORT=8080
SVR_WEB_HTTPS_PORT=8443
SVR_HTTP_PORT=9380
ADMIN_SVR_HTTP_PORT=9381
SVR_MCP_PORT=9382
GO_HTTP_PORT=9384
GO_ADMIN_PORT=9383

MYSQL_PASSWORD=change_me_mysql_please
MYSQL_DBNAME=yourrag
EXPOSE_MYSQL_PORT=3307

MINIO_USER=yourrag
MINIO_PASSWORD=change_me_minio_please
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

REDIS_PASSWORD=change_me_redis_please
REDIS_PORT=6380

RAGFLOW_IMAGE=however-yir/yourrag:v0.1.0
YOURRAG_DOCKER_ENV_FILE=.env.local.lite
